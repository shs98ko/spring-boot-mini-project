<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport"
          content="width=device-width, user-scalable=no, initial-scale=1.0, maximum-scale=1.0, minimum-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>{{pageTitle}}</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet" integrity="sha384-sRIl4kxILFvY47J16cr9ZwB07vP4J8+LH7qKQnuqkuIAvNWLzeN8tE5YBujZqJLB" crossorigin="anonymous">
</head>
<body>
<nav class="navbar navbar-expand bg-body-tertiary">
    <div class="container-fluid">
        <a class="navbar-brand" href="/">Emotion Hub</a>
        <div class="collapse navbar-collapse" id="navbarSupportedContent">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
                <li class="nav-item">
                    <a class="nav-link" href="/articles">Community</a>
                </li>
                {{#loggedIn}}
                    <li class="nav-item">
                        <a class="nav-link" href="/users/logout">Log Out</a>
                    </li>
                    {{#loggedInUser}}
                    <li class="nav-item">
                        <a class="nav-link" href="/users/{{id}}">My page</a>
                    </li>
                    {{/loggedInUser}}
                {{/loggedIn}}
                {{^loggedIn}}
                    <li class="nav-item">
                        <a class="nav-link" href="/join">Sign Up</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" href="/login">Log in</a>
                    </li>
                {{/loggedIn}}
            </ul>
        </div>
    </div>
</nav>