{{>layouts/header}}

<div class="container mt-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">

            <h2 class="fw-bold mb-4">내 정보 수정</h2>

            <div class="card shadow-sm border-0 mb-4">
                <div class="card-body p-4">

                    <h4 class="fw-bold border-bottom pb-3 mb-4">👤 내 정보</h4>

                    <form method="POST">
                        {{#user}}
                            <div class="mb-3">
                                <label for="name" class="form-label fw-bold text-muted">이름</label>
                                <input id="name" name="name" type="text" class="form-control bg-light" placeholder="이름을 입력하세요" required value="{{name}}">
                            </div>

                            <div class="mb-3">
                                <label for="username" class="form-label fw-bold text-muted">아이디</label>
                                <input id="username" name="username" type="text" class="form-control bg-light" placeholder="아이디를 입력하세요" required value="{{username}}">
                            </div>

                            <div class="mb-4">
                                <label for="email" class="form-label fw-bold text-muted">이메일</label>
                                <input id="email" name="email" type="email" class="form-control bg-light" placeholder="이메일을 입력하세요" required value="{{email}}">
                            </div>
                        {{/user}}

                        <div class="d-flex justify-content-between align-items-center mt-4 pt-3 border-top">
                            <a href="/users/{{user.id}}/changepassword" class="text-decoration-none fw-bold text-secondary">
                                🔒 비밀번호 변경
                            </a>
                            <button type="submit" class="btn btn-primary px-4 fw-bold">
                                저장하기
                            </button>
                        </div>
                    </form>

                </div>
            </div>

            <div class="text-center mb-5">
                <a href="/users/{{user.id}}" class="text-muted text-decoration-none">
                    &larr; 마이페이지로 돌아가기
                </a>
            </div>

        </div>
    </div>
</div>

{{>layouts/footer}}