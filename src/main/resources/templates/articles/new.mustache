{{>layouts/header}}

<div class="container mt-5">

    <div class="row justify-content-center">

        <div class="col-md-8">

            <div class="card shadow border-0">
                {{#errorMessage}}
                    <div class="alert alert-danger">{{errorMessage}}</div>
                {{/errorMessage}}

                <div class="card-body p-5">

                    <h1 class="text-center mb-5">
                        오늘의 감정 기록하기
                    </h1>

                    <form action="/articles/post" method="post">

                        <div class="mb-4">

                            <label class="form-label fw-bold">
                                제목
                            </label>

                            <input
                                    type="text"
                                    class="form-control form-control-lg"
                                    name="title"
                                    placeholder="오늘의 감정을 한 줄로 표현해보세요">

                        </div>

                        <div class="mb-4">

                            <label class="form-label fw-bold">
                                내용
                            </label>

                            <textarea
                                    class="form-control"
                                    name="content"
                                    rows="10"
                                    placeholder="오늘 있었던 일을 자유롭게 작성해주세요"></textarea>

                        </div>

                        <div class="d-flex gap-2">

                            <button
                                    type="submit"
                                    class="btn btn-primary flex-fill">

                                등록하기

                            </button>

                            <a
                                    href="/articles"
                                    class="btn btn-outline-secondary flex-fill">

                                취소

                            </a>

                        </div>

                    </form>

                </div>

            </div>

        </div>

    </div>

</div>

{{>layouts/footer}}