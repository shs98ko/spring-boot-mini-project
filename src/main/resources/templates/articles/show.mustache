{{>layouts/header}}

{{#errorMessage}}
    <div class="alert alert-danger">{{errorMessage}}</div>
{{/errorMessage}}

<table class="table">
    <thead>
    <tr><th>Id</th><th>Title</th><th>Content</th></tr>
    </thead>
    <tbody>
    {{#article}}
        <tr>
            <th>{{id}}</th><td>{{title}}</td><td>{{content}}</td>
        </tr>
    {{/article}}
    </tbody>
</table>
<a href="/articles">목록 페이지</a>
{{#article}}
    <a href="/articles/{{id}}/edit" class="btn btn-primary">Edit</a>
    <a href="/articles/{{id}}/delete" class="btn btn-danger">Delete</a>
{{/article}}

{{>layouts/footer}}